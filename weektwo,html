    .fade-in {
      opacity: 0;
      transform: translateY(20px);
      animation: fadeInUp 0.6s ease forwards;
    }
    
    @keyframes fadeInUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    .section-divider {
      height: 3px;
      background: linear-gradient(90deg, #002855 0%, #0070F0 50%, #97E152 100%);
